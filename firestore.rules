rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to menu and blog
    match /menu/{item} {
      allow read: if true;
      allow write: if true; // In production, restrict to authenticated admins
    }
    
    match /blog/{post} {
      allow read: if true;
      allow write: if true;
    }
    
    // Allow creation of orders, but only admins can read all
    match /orders/{order} {
      allow create: if true;
      allow read, update, delete: if true; // Restrict in production
    }

    // Staff records
    match /staff/{member} {
      allow read, write: if true;
    }
    
    // Fallback for everything else
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 12, 31);
    }
  }
}
