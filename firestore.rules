rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is a staff member with a specific role
    function isStaff() {
      return request.auth != null && exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return request.auth != null && getRole() == 'admin';
    }

    // Public: Read-only access to Menu and Blog
    match /menu/{item} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /blog/{post} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: Public can create, but only staff can read/update
    match /orders/{order} {
      allow create: if true;
      allow read: if true; // Tracking page needs read access. Ideally restricted by orderId + phone check.
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // Staff: Protected access
    match /staff/{member} {
      // Allow users to read their own profile, admins read all
      allow read: if request.auth != null && (request.auth.uid == member || isAdmin());
      // Allow the primary admin to create their own record during bootstrap
      allow create: if request.auth != null && member == request.auth.uid && request.auth.token.email == "bamandakitchen25@gmail.com";
      // Only admins can update or delete staff
      allow update, delete: if isAdmin();
    }
    
    // Logs: Write-only for public, read for staff
    match /tracking_logs/{log} {
      allow create: if true;
      allow read: if isStaff();
      allow update, delete: if isAdmin();
    }
  }
}
